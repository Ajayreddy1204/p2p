def delete_s3_prefix(bucket, prefix):
    s3 = boto3.resource('s3')
    try:
        s3.Bucket(bucket).objects.filter(Prefix=prefix).delete()
        logger.info(f"Deleted existing files under s3://{bucket}/{prefix}")
    except Exception as e:
        logger.warning(f"Could not delete s3://{bucket}/{prefix}: {e}")

def find_column(df, col_name):
    for c in df.columns:
        if c.upper() == col_name.upper():
            return c
    return None

def get_existing_columns(df, columns):
    """Return unique list of column names that exist in df, case-insensitive."""
    existing = set()
    for c in columns:
        found = find_column(df, c)
        if found:
            existing.add(found)
    return list(existing)

def write_to_s3(df, s3_path):
    full_path = f"s3://{raw_vault_bucket}/{s3_path}"
    df = deduplicate_columns(df)  # safety
    if df.rdd.isEmpty():
        logger.warning(f"No data for {s3_path}, writing empty DataFrame with schema.")
        df.write.mode("overwrite").parquet(full_path)
    else:
        df.write.mode("overwrite").parquet(full_path)
    logger.info(f"Written {df.count()} rows to {full_path}")

def generate_hash_key(df, columns, key_name):
    existing_cols = get_existing_columns(df, columns)
    if not existing_cols:
        return None
    # Ensure no duplicate column references
    existing_cols = list(dict.fromkeys(existing_cols))  # preserve order but deduplicate
    concat_expr = concat_ws("||", *[coalesce(col(c).cast(StringType()), lit("")) for c in existing_cols])
    return df.withColumn(key_name, sha2(concat_expr, 256))

def create_empty_hub(bk_columns, hub_hash_key_name):
    bk_columns = list(dict.fromkeys(bk_columns))  # deduplicate
    schema_cols = bk_columns + [hub_hash_key_name, "BUSINESS_KEY", "LOAD_DTS", "RECORD_SOURCE"]
    empty_df = spark.createDataFrame([], schema=StructType([StructField(c, StringType(), True) for c in schema_cols]))
    return deduplicate_columns(empty_df)

def create_empty_link(link_hash_key_name, hub_hash_key_names):
    hub_hash_key_names = list(dict.fromkeys(hub_hash_key_names))
    schema_cols = [link_hash_key_name] + hub_hash_key_names + ["LOAD_DTS", "RECORD_SOURCE"]
    empty_df = spark.createDataFrame([], schema=StructType([StructField(c, StringType(), True) for c in schema_cols]))
    return deduplicate_columns(empty_df)

def create_empty_satellite(hub_hash_key_name, attributes):
    attributes = list(dict.fromkeys(attributes))
    schema_cols = [hub_hash_key_name] + attributes + ["HASH_DIFF", "LOAD_DTS", "RECORD_SOURCE", "END_DTS"]
    empty_df = spark.createDataFrame([], schema=StructType([StructField(c, StringType(), True) for c in schema_cols]))
    return deduplicate_columns(empty_df)

# --------------------------------------------------------------
# Dynamically discover tables in the Glue database
# --------------------------------------------------------------
def get_table_names_from_database(database_name):
    try:
        tables_df = spark.sql(f"SHOW TABLES IN {database_name}")
        table_names = [row.tableName for row in tables_df.collect()]
        logger.info(f"Discovered {len(table_names)} tables in database {database_name}")
        return table_names
    except Exception as e:
        logger.error(f"Failed to list tables: {e}")
        raise

# --------------------------------------------------------------
# Load and cache all source tables with translated columns (once)
# --------------------------------------------------------------
def load_and_cache_source_tables():
    source_tables = get_table_names_from_database(bronze_db)
    if not source_tables:
        logger.error(f"No tables found in database {bronze_db}. Exiting.")
        sys.exit(1)

    logger.info(f"Collecting all column names from {len(source_tables)} source tables...")
    all_columns = set()
    for table in source_tables:
        try:
            df_schema = spark.table(f"{bronze_db}.{table}")
            all_columns.update(df_schema.columns)
        except Exception as e:
            logger.warning(f"Could not get schema for table {table}: {e}")

    logger.info(f"Collected {len(all_columns)} unique column names.")
    translator = BatchedLLMColumnTranslator()
    global_translation_map = translator.translate_batch(list(all_columns))

    source_dfs = {}
    for table in source_tables:
        try:
            df = spark.table(f"{bronze_db}.{table}")
            df = translator.rename_columns(df, global_translation_map)
            df = deduplicate_columns(df)
            df.cache()
            row_count = df.count()
            logger.info(f"Cached table {table}: {len(df.columns)} cols, {row_count} rows.")
            source_dfs[table] = df
        except Exception as e:
            logger.warning(f"Could not read table {table}: {e}")
            source_dfs[table] = None
    return source_dfs, global_translation_map

# --------------------------------------------------------------
# Build schema description from cached DataFrames (already English)
# --------------------------------------------------------------
def build_schema_description(source_dfs):
    schema_info = {}
    for table, df in source_dfs.items():
        if df is not None:
            schema_info[table.upper()] = df.columns
            logger.info(f"Table {table.upper()} columns: {df.columns}")
        else:
            logger.warning(f"Table {table} not found, skipping.")
    return schema_info

# --------------------------------------------------------------
# Generate Data Vault Model via LLM (uses only English column names)
# --------------------------------------------------------------
@bedrock_retry(max_retries=3, initial_delay=2, backoff=2)
def _invoke_model_generation(prompt):
    bedrock = boto3.client('bedrock-runtime', region_name=BEDROCK_REGION, config=BEDROCK_CONFIG)
    body = json.dumps({
        "prompt": prompt,
        "max_gen_len": 8000,
        "temperature": 0.0,
        "top_p": 0.9
    })
    response = bedrock.invoke_model(
        modelId=BEDROCK_MODEL_ID,
        contentType='application/json',
        accept='application/json',
        body=body
    )
    response_body = json.loads(response['body'].read())
    json_text = response_body.get('generation', '').strip()
    if not json_text and 'outputs' in response_body:
        json_text = response_body['outputs'][0].get('text', '').strip()
    return json_text

def validate_column_names(vault_model, source_dfs, translation_map):
    all_source_columns = set()
    for df in source_dfs.values():
        if df is not None:
            all_source_columns.update([c.upper() for c in df.columns])

    def fix_column(col_name, context):
        upper_col = col_name.upper()
        if upper_col in all_source_columns:
            for df in source_dfs.values():
                if df is not None and upper_col in [c.upper() for c in df.columns]:
                    return next(c for c in df.columns if c.upper() == upper_col)
            return col_name
        if col_name in translation_map:
            english = translation_map[col_name]
            if english.upper() in all_source_columns:
                logger.warning(f"Replaced German column '{col_name}' with '{english}' in {context}")
                return english
        for source_col in all_source_columns:
            if source_col.upper() == upper_col:
                return source_col
        raise RuntimeError(f"Column '{col_name}' used in {context} does not exist. Available: {list(all_source_columns)[:20]}")

    for hub in vault_model.get("hubs", []):
        if "business_key_columns" in hub:
            hub["business_key_columns"] = [fix_column(c, f"hub {hub.get('hub_name')}") for c in hub["business_key_columns"]]
            hub["business_key_columns"] = list(dict.fromkeys(hub["business_key_columns"]))
    for link in vault_model.get("links", []):
        for ref in link.get("hub_references", []):
            if "columns" in ref:
                ref["columns"] = [fix_column(c, f"link {link.get('link_name')}") for c in ref["columns"]]
                ref["columns"] = list(dict.fromkeys(ref["columns"]))
    for sat in vault_model.get("satellites", []):
        if "hub_key_columns" in sat:
            sat["hub_key_columns"] = [fix_column(c, f"satellite {sat.get('sat_name')} hub_key") for c in sat["hub_key_columns"]]
            sat["hub_key_columns"] = list(dict.fromkeys(sat["hub_key_columns"]))
        if "attributes" in sat:
            sat["attributes"] = [fix_column(c, f"satellite {sat.get('sat_name')} attr") for c in sat["attributes"]]
            sat["attributes"] = list(dict.fromkeys(sat["attributes"]))
    return vault_model

def ensure_full_column_coverage(vault_model, schema_info, source_dfs):
    covered_per_table = {}
    for sat in vault_model["satellites"]:
        src_table = sat.get("source_table", "").upper()
        if not src_table:
            continue
        attrs = set(sat.get("attributes", []))
        covered_per_table[src_table] = covered_per_table.get(src_table, set()).union(attrs)

    missing_per_table = {}
    for table, required_cols in schema_info.items():
        covered = covered_per_table.get(table, set())
        missing = set(required_cols) - covered
        if missing:
            missing_per_table[table] = missing

    if not missing_per_table:
        logger.info("All columns are already covered.")
        return vault_model

    logger.warning(f"Found missing columns for {len(missing_per_table)} source tables. Auto-remediating...")

    for table, missing_cols in missing_per_table.items():
        existing_sats = [sat for sat in vault_model["satellites"] if sat.get("source_table", "").upper() == table]
        if existing_sats:
            target_sat = existing_sats[0]
            original_attrs = set(target_sat.get("attributes", []))
            target_sat["attributes"] = list(original_attrs.union(missing_cols))
            logger.info(f"Added {len(missing_cols)} missing columns to existing satellite {target_sat['sat_name']} for table {table}")
        else:
            # Find a hub or create one
            hub_name = None
            hub_key_columns = []
            for hub in vault_model["hubs"]:
                if table in [st.upper() for st in hub.get("source_tables", [])]:
                    hub_name = hub["hub_name"]
                    hub_key_columns = hub.get("business_key_columns", [])
                    break
            if not hub_name:
                hub_name = f"HUB_{table}"
                business_key_col = list(missing_cols)[0] if missing_cols else "DUMMY_KEY"
                new_hub = {
                    "hub_name": hub_name,
                    "entity_name": table,
                    "business_key_columns": [business_key_col],
                    "source_tables": [table]
                }
                vault_model["hubs"].append(new_hub)
                logger.info(f"Created new hub {hub_name} for table {table}")
                hub_key_columns = [business_key_col]
            sat_name = f"SAT_{table}_AUTO"
            new_sat = {
                "sat_name": sat_name,
                "hub_name": hub_name,
                "hub_key_columns": hub_key_columns,
                "attributes": list(missing_cols),
                "source_table": table
            }
            vault_model["satellites"].append(new_sat)
            logger.info(f"Created new satellite {sat_name} for table {table} covering {len(missing_cols)} columns")

    # Re-validate
    covered_per_table = {}
    for sat in vault_model["satellites"]:
        src_table = sat.get("source_table", "").upper()
        if src_table:
            attrs = set(sat.get("attributes", []))
            covered_per_table[src_table] = covered_per_table.get(src_table, set()).union(attrs)
    still_missing = {}
    for table, required_cols in schema_info.items():
        covered = covered_per_table.get(table, set())
        missing = set(required_cols) - covered
        if missing:
            still_missing[table] = missing
    if still_missing:
        error_msg = "FATAL: After auto-remediation, columns are still missing:\n"
        for table, cols in still_missing.items():
            error_msg += f"  Table {table}: {sorted(cols)}\n"
        raise RuntimeError(error_msg)
    logger.info("Column coverage enforced successfully.")
    return vault_model

def generate_vault_model_from_llm(schema_info, translation_map, source_dfs):
    schema_str = ""
    for table, cols in schema_info.items():
        schema_str += f"Table {table}: columns = {cols}\n"

    prompt = f"""<|begin_of_text|><|start_header_id|>user<|end_header_id|>

You are a Data Vault 2.0 expert. The source tables below have ALREADY been translated to English column names.
**CRITICAL**: You MUST use the EXACT column names as they appear in the schema. 
Do NOT use any German abbreviations like 'bukrs', 'belnr', 'lifnr', 'matnr', etc.
For example, if the schema shows 'COMPANY_CODE', use 'COMPANY_CODE' – never 'bukrs'.

**REQUIREMENTS**:
- **Every column** from every source table must appear in the `attributes` list of some satellite.
- Hubs: 10–15 tables. Links: ~10 tables. Satellites: 10–20 tables.
- Table names must be in English (e.g., HUB_COMPANY, SAT_ACCOUNTING_DOCUMENT_HEADER). No German table names.

**Output format**: Return a single JSON object with three lists:
- "hubs": list of {{"hub_name": string, "entity_name": string, "business_key_columns": [string], "source_tables": [string]}}
- "links": list of {{"link_name": string, "entity_name": string, "hub_references": [{{"hub_name": string, "columns": [string]}}], "source_tables": [string]}}
- "satellites": list of {{"sat_name": string, "hub_name": string, "hub_key_columns": [string], "attributes": [string], "source_table": string}}

Return ONLY valid JSON. No extra text.

Source schema (all column names are already in English):
{schema_str}
<|eot_id|><|start_header_id|>assistant<|end_header_id|>

"""

    try:
        json_text = _invoke_model_generation(prompt)
    except Exception as e:
        logger.error(f"LLM model generation failed: {e}. Cannot proceed.")
        sys.exit(1)

    logger.info(f"Raw response length: {len(json_text)} characters")
    first_brace = json_text.find('{')
    last_brace = json_text.rfind('}')
    if first_brace != -1 and last_brace != -1 and last_brace > first_brace:
        json_text = json_text[first_brace:last_brace+1]
    else:
        raise ValueError("No JSON object found in LLM response")

    json_text = re.sub(r',\s*}', '}', json_text)
    json_text = re.sub(r',\s*]', ']', json_text)

    try:
        vault_model = json.loads(json_text)
    except json.JSONDecodeError as e:
        logger.error(f"JSON decode error: {e}")
        logger.error(f"Raw JSON text (first 2000 chars): {json_text[:2000]}")
        raise ValueError(f"Failed to parse LLM response as JSON. Error at {e}.")

    for key in ["hubs", "links", "satellites"]:
        if key not in vault_model:
            raise ValueError(f"LLM response missing '{key}' key")

    vault_model = validate_column_names(vault_model, source_dfs, translation_map)

    hub_names = {h["hub_name"] for h in vault_model["hubs"]}
    cleaned_satellites = []
    for sat in vault_model["satellites"]:
        hub_name = sat.get("hub_name")
        if not hub_name:
            logger.warning(f"Satellite {sat.get('sat_name')} has no hub_name. Assigning to 'HUB_DUMMY'.")
            sat["hub_name"] = "HUB_DUMMY"
            hub_name = "HUB_DUMMY"
        if hub_name not in hub_names:
            logger.warning(f"Satellite {sat['sat_name']} references missing hub {hub_name}. Creating hub automatically.")
            new_hub = {
                "hub_name": hub_name,
                "entity_name": hub_name.replace("HUB_", ""),
                "business_key_columns": sat.get("hub_key_columns", []),
                "source_tables": [sat.get("source_table", "UNKNOWN")]
            }
            vault_model["hubs"].append(new_hub)
            hub_names.add(hub_name)
        cleaned_satellites.append(sat)
    vault_model["satellites"] = cleaned_satellites

    vault_model["hubs"] = [h for h in vault_model["hubs"] if h.get("business_key_columns")]

    vault_model = ensure_full_column_coverage(vault_model, schema_info, source_dfs)

    total_tables = len(vault_model["hubs"]) + len(vault_model["links"]) + len(vault_model["satellites"])
    logger.info(f"Final model: {len(vault_model['hubs'])} hubs, {len(vault_model['links'])} links, {len(vault_model['satellites'])} satellites (total {total_tables} tables).")
    return vault_model

# --------------------------------------------------------------
# Data Vault Table Creation Functions
# --------------------------------------------------------------
def create_hubs(vault_model, source_dfs):
    logger.info("=" * 60)
    logger.info("Creating HUB Tables")
    logger.info("=" * 60)
    for hub in vault_model["hubs"]:
        hub_name = hub["hub_name"]
        entity_name = hub["entity_name"]
        bk_columns = list(dict.fromkeys(hub["business_key_columns"]))
        source_tables = hub["source_tables"]
        hub_hash_key_name = f"{entity_name}_HK"
        logger.info(f"Building HUB: {hub_name} (HK: {hub_hash_key_name})")
        hub_dfs = []
        for src_table in source_tables:
            src_df = source_dfs.get(src_table.lower())
            if src_df is None:
                continue
            existing_bk = get_existing_columns(src_df, bk_columns)
            if not existing_bk:
                logger.warning(f"No business key columns found in {src_table} for {hub_name}. Columns: {src_df.columns}")
                continue
            key_df = src_df.select(*[col(c) for c in existing_bk]).distinct()
            key_df = generate_hash_key(key_df, existing_bk, hub_hash_key_name)
            if key_df is None:
                continue
            key_df = key_df.withColumn("LOAD_DTS", current_timestamp())
            key_df = key_df.withColumn("RECORD_SOURCE", lit(src_table))
            key_df = key_df.withColumn("BUSINESS_KEY", concat_ws("|", *[col(c) for c in existing_bk]))
            hub_dfs.append(key_df)
        if not hub_dfs:
            hub_df = create_empty_hub(bk_columns, hub_hash_key_name)
        else:
            hub_df = hub_dfs[0]
            for df in hub_dfs[1:]:
                hub_df = hub_df.unionByName(df, allowMissingColumns=True)
            hub_df = hub_df.dropDuplicates([hub_hash_key_name])
        hub_df = deduplicate_columns(hub_df)
        delete_s3_prefix(raw_vault_bucket, f"{hub_path}/{hub_name}")
        write_to_s3(hub_df, f"{hub_path}/{hub_name}")

def create_satellites(vault_model, source_dfs):
    logger.info("=" * 60)
    logger.info("Creating SATELLITE Tables")
    logger.info("=" * 60)
    for sat in vault_model["satellites"]:
        sat_name = sat["sat_name"]
        hub_name = sat.get("hub_name")
        if not hub_name:
            logger.error(f"Satellite {sat_name} has no hub_name. Skipping.")
            continue
        hub_key_columns = list(dict.fromkeys(sat["hub_key_columns"]))
        source_table = sat["source_table"]
        hub_def = next((h for h in vault_model["hubs"] if h["hub_name"] == hub_name), None)
        if hub_def is None:
            logger.error(f"Hub {hub_name} not found for satellite {sat_name}, skipping.")
            continue
        hub_hash_key_name = f"{hub_def['entity_name']}_HK"
        logger.info(f"Building SATELLITE: {sat_name} (HK: {hub_hash_key_name})")

        src_df = source_dfs.get(source_table.lower())
        if src_df is None:
            sat_df = create_empty_satellite(hub_hash_key_name, [])
            delete_s3_prefix(raw_vault_bucket, f"{sat_path}/{sat_name}")
            write_to_s3(sat_df, f"{sat_path}/{sat_name}")
            continue

        existing_hub_keys = get_existing_columns(src_df, hub_key_columns)
        if not existing_hub_keys:
            logger.warning(f"Hub key columns {hub_key_columns} not found in {source_table}. Creating empty satellite.")
            sat_df = create_empty_satellite(hub_hash_key_name, [])
            delete_s3_prefix(raw_vault_bucket, f"{sat_path}/{sat_name}")
            write_to_s3(sat_df, f"{sat_path}/{sat_name}")
            continue

        sat_df = generate_hash_key(src_df, existing_hub_keys, hub_hash_key_name)
        if sat_df is None:
            sat_df = create_empty_satellite(hub_hash_key_name, [])
            delete_s3_prefix(raw_vault_bucket, f"{sat_path}/{sat_name}")
            write_to_s3(sat_df, f"{sat_path}/{sat_name}")
            continue

        reserved = set(existing_hub_keys + [hub_hash_key_name])
        all_cols = set(sat_df.columns)
        attributes = list(all_cols - reserved)
        for meta in ["LOAD_DTS", "RECORD_SOURCE", "HASH_DIFF", "END_DTS"]:
            if meta in attributes:
                attributes.remove(meta)
        attributes = list(dict.fromkeys(attributes))

        if not attributes:
            logger.warning(f"No attributes found for satellite {sat_name}. Creating empty satellite.")
            sat_df = create_empty_satellite(hub_hash_key_name, [])
        else:
            attr_concat = concat_ws("||", *[coalesce(col(c).cast(StringType()), lit("")) for c in attributes])
            sat_df = sat_df.withColumn("HASH_DIFF", sha2(attr_concat, 256))
            sat_df = sat_df.withColumn("LOAD_DTS", current_timestamp())
            sat_df = sat_df.withColumn("RECORD_SOURCE", lit(source_table))
            sat_df = sat_df.withColumn("END_DTS", lit(None).cast(StringType()))
            select_cols = [hub_hash_key_name] + attributes + ["HASH_DIFF", "LOAD_DTS", "RECORD_SOURCE", "END_DTS"]
            select_cols = [c for c in select_cols if c in sat_df.columns]
            sat_df = sat_df.select(*select_cols).distinct()

        sat_df = deduplicate_columns(sat_df)
        delete_s3_prefix(raw_vault_bucket, f"{sat_path}/{sat_name}")
        write_to_s3(sat_df, f"{sat_path}/{sat_name}")

def create_links(vault_model, source_dfs):
    logger.info("=" * 60)
    logger.info("Creating LINK Tables")
    logger.info("=" * 60)
    for link in vault_model["links"]:
        link_name = link["link_name"]
        entity_name = link["entity_name"]
        hub_references = link["hub_references"]
        source_tables = link["source_tables"]
        link_hash_key_name = f"LINK_{entity_name}_HK"
        logger.info(f"Building LINK: {link_name} (HK: {link_hash_key_name})")
        link_dfs = []
        for src_table in source_tables:
            src_df = source_dfs.get(src_table.lower())
            if src_df is None:
                continue
            current_df = src_df
            hub_hash_key_names = []
            valid = True
            for ref in hub_references:
                hub_name = ref["hub_name"]
                ref_columns = list(dict.fromkeys(ref["columns"]))
                hub_def = next((h for h in vault_model["hubs"] if h["hub_name"] == hub_name), None)
                if hub_def is None:
                    logger.error(f"Hub {hub_name} not found for link {link_name}, skipping source {src_table}")
                    valid = False
                    break
                target_hk_name = f"{hub_def['entity_name']}_HK"
                existing_cols = get_existing_columns(current_df, ref_columns)
                if not existing_cols:
                    logger.warning(f"Columns {ref_columns} not found in {src_table} for link {link_name}")
                    valid = False
                    break
                current_df = generate_hash_key(current_df, existing_cols, target_hk_name)
                if current_df is None:
                    valid = False
                    break
                hub_hash_key_names.append(target_hk_name)
            if not valid:
                continue
            # Deduplicate hub hash key names
            hub_hash_key_names = list(dict.fromkeys(hub_hash_key_names))
            link_concat = concat_ws("||", *[col(hk) for hk in hub_hash_key_names])
            current_df = current_df.withColumn(link_hash_key_name, sha2(link_concat, 256))
            current_df = current_df.withColumn("LOAD_DTS", current_timestamp())
            current_df = current_df.withColumn("RECORD_SOURCE", lit(src_table))
            select_cols = [link_hash_key_name] + hub_hash_key_names + ["LOAD_DTS", "RECORD_SOURCE"]
            select_cols = list(dict.fromkeys(select_cols))
            current_df = current_df.select(*select_cols).distinct()
            link_dfs.append(current_df)
        if not link_dfs:
            hub_hk_names = []
            for ref in hub_references:
                hub_def = next((h for h in vault_model["hubs"] if h["hub_name"] == ref["hub_name"]), None)
                if hub_def:
                    hub_hk_names.append(f"{hub_def['entity_name']}_HK")
            hub_hk_names = list(dict.fromkeys(hub_hk_names))
            link_df = create_empty_link(link_hash_key_name, hub_hk_names)
        else:
            link_df = link_dfs[0]
            for df in link_dfs[1:]:
                link_df = link_df.unionByName(df, allowMissingColumns=True)
            link_df = link_df.dropDuplicates([link_hash_key_name])
        link_df = deduplicate_columns(link_df)
        delete_s3_prefix(raw_vault_bucket, f"{link_path}/{link_name}")
        write_to_s3(link_df, f"{link_path}/{link_name}")

# --------------------------------------------------------------
# Main
# --------------------------------------------------------------
def main():
    logger.info("Starting Silver Layer Job: Chunked LLM translation, deduplicated columns, 100% coverage.")

    source_dfs, translation_map = load_and_cache_source_tables()
    schema_info = build_schema_description(source_dfs)
    if not schema_info:
        logger.error("No source tables found. Exiting.")
        job.commit()
        sys.exit(1)

    vault_model = generate_vault_model_from_llm(schema_info, translation_map, source_dfs)

    delete_s3_prefix(raw_vault_bucket, hub_path)
    delete_s3_prefix(raw_vault_bucket, link_path)
    delete_s3_prefix(raw_vault_bucket, sat_path)

    create_hubs(vault_model, source_dfs)
    create_satellites(vault_model, source_dfs)
    create_links(vault_model, source_dfs)

    total_created = len(vault_model["hubs"]) + len(vault_model["links"]) + len(vault_model["satellites"])
    logger.info(f"Job completed. Created {total_created} Data Vault tables with 100% English column names and full coverage.")
    job.commit()

if __name__ == "__main__":
    main()
