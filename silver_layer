# --------------------------------------------------------------
# Helper Functions
# --------------------------------------------------------------
def rename_columns_german_to_english(df):
    """Rename all columns from German to English using the global mapping."""
    for german, english in GERMAN_TO_ENGLISH.items():
        if german in df.columns:
            df = df.withColumnRenamed(german, english)
    return df

def find_column(df, col_name):
    """Case-insensitive column lookup (English names are already uppercase)."""
    for c in df.columns:
        if c.upper() == col_name.upper():
            return c
    return None

def get_existing_columns(df, columns):
    """Return list of columns that exist in the DataFrame (English names)."""
    existing = []
    for c in columns:
        found = find_column(df, c)
        if found:
            existing.append(found)
    return existing

def write_to_s3(df, s3_path, mode="overwrite"):
    """Write DataFrame to S3 as Parquet. If df is empty, create an empty file with correct schema."""
    full_path = f"s3://{raw_vault_bucket}/{s3_path}"
    if df.rdd.isEmpty():
        # Write empty DataFrame with the current schema
        logger.warning(f"No data for {s3_path}, writing empty DataFrame with schema.")
        df.write.mode(mode).parquet(full_path)
    else:
        df.write.mode(mode).parquet(full_path)
    logger.info(f"Written {df.count()} rows to {full_path}")

def read_bronze_table(table_name):
    """Read a table from bronze database and rename columns to English."""
    try:
        df = spark.table(f"{bronze_db}.{table_name.lower()}")
        df = rename_columns_german_to_english(df)
        logger.info(f"Read table {table_name} with {len(df.columns)} columns (renamed to English).")
        return df
    except Exception as e:
        logger.warning(f"Could not read table {table_name}: {e}")
        return None

def generate_hash_key(df, columns, key_name):
    """Generate SHA-256 hash key from a list of columns."""
    existing_cols = get_existing_columns(df, columns)
    if not existing_cols:
        return None
    concat_expr = concat_ws("||", *[coalesce(col(c).cast(StringType()), lit("")) for c in existing_cols])
    return df.withColumn(key_name, sha2(concat_expr, 256))

def create_empty_hub(hub, hub_hash_key_name):
    """Create an empty DataFrame with the required HUB schema."""
    bk_cols = hub["business_key_columns"]
    schema_cols = bk_cols + [hub_hash_key_name, "BUSINESS_KEY", "LOAD_DTS", "RECORD_SOURCE"]
    empty_df = spark.createDataFrame([], schema=StructType([StructField(c, StringType(), True) for c in schema_cols]))
    return empty_df

def create_empty_link(link, link_hash_key_name, hub_hash_key_names):
    """Create an empty DataFrame with the required LINK schema."""
    schema_cols = [link_hash_key_name] + hub_hash_key_names + ["LOAD_DTS", "RECORD_SOURCE"]
    empty_df = spark.createDataFrame([], schema=StructType([StructField(c, StringType(), True) for c in schema_cols]))
    return empty_df

def create_empty_satellite(sat, hub_hash_key_name, attributes):
    """Create an empty DataFrame with the required SATELLITE schema."""
    schema_cols = [hub_hash_key_name] + attributes + ["HASH_DIFF", "LOAD_DTS", "RECORD_SOURCE"]
    empty_df = spark.createDataFrame([], schema=StructType([StructField(c, StringType(), True) for c in schema_cols]))
    return empty_df

# --------------------------------------------------------------
# Create HUB Tables
# --------------------------------------------------------------
def create_hubs():
    logger.info("=" * 60)
    logger.info("Creating HUB Tables")
    logger.info("=" * 60)

    hub_dataframes = {}

    for hub in VAULT_MODEL["hubs"]:
        hub_name = hub["hub_name"]
        entity_name = hub["entity_name"]
        bk_columns = hub["business_key_columns"]
        source_tables = hub["source_tables"]
        hub_hash_key_name = f"{entity_name}_HK"

        logger.info(f"Building HUB: {hub_name} (HK: {hub_hash_key_name})")

        hub_dfs = []
        for src_table in source_tables:
            src_df = read_bronze_table(src_table)
            if src_df is None:
                continue

            existing_bk = get_existing_columns(src_df, bk_columns)
            if not existing_bk:
                logger.warning(f"No business key columns found in {src_table} for {hub_name}")
                continue

            # Select business key columns
            key_df = src_df.select(*[col(c) for c in existing_bk]).distinct()

            # Generate hash key
            key_df = generate_hash_key(key_df, existing_bk, hub_hash_key_name)
            if key_df is None:
                continue

            key_df = key_df.withColumn("LOAD_DTS", current_timestamp())
            key_df = key_df.withColumn("RECORD_SOURCE", lit(src_table))
            # Create business_key for debugging (concatenated string)
            key_df = key_df.withColumn("BUSINESS_KEY", concat_ws("|", *[col(c) for c in existing_bk]))

            hub_dfs.append(key_df)

        if not hub_dfs:
            logger.warning(f"No data for HUB {hub_name}, creating empty DataFrame.")
            hub_df = create_empty_hub(hub, hub_hash_key_name)
        else:
            hub_df = hub_dfs[0]
            for df in hub_dfs[1:]:
                hub_df = hub_df.unionByName(df, allowMissingColumns=True)
            hub_df = hub_df.dropDuplicates([hub_hash_key_name])

        write_to_s3(hub_df, f"{hub_path}/{hub_name}")
        hub_dataframes[hub_name] = f"s3://{raw_vault_bucket}/{hub_path}/{hub_name}"

    return hub_dataframes

# --------------------------------------------------------------
# Create SATELLITE Tables
# --------------------------------------------------------------
def create_satellites(hub_paths):
    logger.info("=" * 60)
    logger.info("Creating SATELLITE Tables")
    logger.info("=" * 60)

    for sat in VAULT_MODEL["satellites"]:
        sat_name = sat["sat_name"]
        hub_name = sat["hub_name"]
        hub_key_columns = sat["hub_key_columns"]
        attributes = sat["attributes"]
        source_table = sat["source_table"]

        # Find the corresponding hub to get the correct HK column name
        hub_def = next((h for h in VAULT_MODEL["hubs"] if h["hub_name"] == hub_name), None)
        if hub_def is None:
            logger.error(f"Hub {hub_name} not found for satellite {sat_name}, skipping.")
            continue
        hub_hash_key_name = f"{hub_def['entity_name']}_HK"

        logger.info(f"Building SATELLITE: {sat_name} (HK: {hub_hash_key_name})")

        src_df = read_bronze_table(source_table)
        if src_df is None:
            logger.warning(f"Source table {source_table} missing for satellite {sat_name}, creating empty DataFrame.")
            sat_df = create_empty_satellite(sat, hub_hash_key_name, attributes)
            write_to_s3(sat_df, f"{sat_path}/{sat_name}")
            continue

        # Get existing hub key columns (in English)
        existing_hub_keys = get_existing_columns(src_df, hub_key_columns)
        existing_attrs = get_existing_columns(src_df, attributes)

        if not existing_hub_keys:
            logger.warning(f"Hub key columns {hub_key_columns} not found in {source_table}, creating empty satellite.")
            sat_df = create_empty_satellite(sat, hub_hash_key_name, attributes)
            write_to_s3(sat_df, f"{sat_path}/{sat_name}")
            continue

        # Generate hub hash key
        sat_df = generate_hash_key(src_df, existing_hub_keys, hub_hash_key_name)
        if sat_df is None:
            logger.warning(f"Could not generate HK for {sat_name}, creating empty.")
            sat_df = create_empty_satellite(sat, hub_hash_key_name, attributes)
            write_to_s3(sat_df, f"{sat_path}/{sat_name}")
            continue

        # Generate hash_diff if there are attributes
        if existing_attrs:
            attr_concat = concat_ws("||", *[coalesce(col(c).cast(StringType()), lit("")) for c in existing_attrs])
            sat_df = sat_df.withColumn("HASH_DIFF", sha2(attr_concat, 256))
        else:
            sat_df = sat_df.withColumn("HASH_DIFF", lit(None).cast(StringType()))

        sat_df = sat_df.withColumn("LOAD_DTS", current_timestamp())
        sat_df = sat_df.withColumn("RECORD_SOURCE", lit(source_table))

        # Select final columns
        select_cols = [hub_hash_key_name] + existing_attrs + ["HASH_DIFF", "LOAD_DTS", "RECORD_SOURCE"]
        sat_df = sat_df.select(*select_cols).distinct()

        write_to_s3(sat_df, f"{sat_path}/{sat_name}")

# --------------------------------------------------------------
# Create LINK Tables
# --------------------------------------------------------------
def create_links(hub_paths):
    logger.info("=" * 60)
    logger.info("Creating LINK Tables")
    logger.info("=" * 60)

    for link in VAULT_MODEL["links"]:
        link_name = link["link_name"]
        entity_name = link["entity_name"]
        hub_references = link["hub_references"]
        source_tables = link["source_tables"]
        link_hash_key_name = f"LINK_{entity_name}_HK"

        logger.info(f"Building LINK: {link_name} (HK: {link_hash_key_name})")

        link_dfs = []
        for src_table in source_tables:
            src_df = read_bronze_table(src_table)
            if src_df is None:
                continue

            current_df = src_df
            hub_hash_key_names = []
            valid = True

            for ref in hub_references:
                hub_name = ref["hub_name"]
                ref_columns = ref["columns"]

                # Find hub definition to get the correct HK column name
                hub_def = next((h for h in VAULT_MODEL["hubs"] if h["hub_name"] == hub_name), None)
                if hub_def is None:
                    logger.error(f"Hub {hub_name} not found for link {link_name}, skipping source {src_table}")
                    valid = False
                    break
                target_hk_name = f"{hub_def['entity_name']}_HK"

                existing_cols = get_existing_columns(current_df, ref_columns)
                if not existing_cols:
                    logger.warning(f"Columns {ref_columns} not found in {src_table} for link {link_name}")
                    valid = False
                    break

                # Generate the hub hash key column with the correct name
                current_df = generate_hash_key(current_df, existing_cols, target_hk_name)
                if current_df is None:
                    valid = False
                    break
                hub_hash_key_names.append(target_hk_name)

            if not valid:
                continue

            # Generate link hash key from all hub hash keys
            link_concat = concat_ws("||", *[col(hk) for hk in hub_hash_key_names])
            current_df = current_df.withColumn(link_hash_key_name, sha2(link_concat, 256))

            current_df = current_df.withColumn("LOAD_DTS", current_timestamp())
            current_df = current_df.withColumn("RECORD_SOURCE", lit(src_table))

            select_cols = [link_hash_key_name] + hub_hash_key_names + ["LOAD_DTS", "RECORD_SOURCE"]
            current_df = current_df.select(*select_cols).distinct()

            link_dfs.append(current_df)

        if not link_dfs:
            logger.warning(f"No data for LINK {link_name}, creating empty DataFrame.")
            # Build empty schema for this link
            hub_hk_names = []
            for ref in hub_references:
                hub_def = next((h for h in VAULT_MODEL["hubs"] if h["hub_name"] == ref["hub_name"]), None)
                if hub_def:
                    hub_hk_names.append(f"{hub_def['entity_name']}_HK")
            link_df = create_empty_link(link, link_hash_key_name, hub_hk_names)
        else:
            link_df = link_dfs[0]
            for df in link_dfs[1:]:
                link_df = link_df.unionByName(df, allowMissingColumns=True)
            link_df = link_df.dropDuplicates([link_hash_key_name])

        write_to_s3(link_df, f"{link_path}/{link_name}")

