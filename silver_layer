# --------------------------------------------------------------
# Helper: Retry decorator for Bedrock calls
# --------------------------------------------------------------
def bedrock_retry(max_retries=3, initial_delay=2, backoff=2):
    def decorator(func):
        def wrapper(*args, **kwargs):
            delay = initial_delay
            for attempt in range(max_retries):
                try:
                    return func(*args, **kwargs)
                except Exception as e:
                    if attempt == max_retries - 1:
                        raise
                    logger.warning(f"Bedrock call failed (attempt {attempt+1}/{max_retries}): {e}. Retrying in {delay}s...")
                    time.sleep(delay)
                    delay *= backoff
            return None
        return wrapper
    return decorator

# --------------------------------------------------------------
# Batched LLM Column Translator (chunked, robust JSON)
# --------------------------------------------------------------
class BatchedLLMColumnTranslator:
    def __init__(self, region=BEDROCK_REGION, model_id=BEDROCK_MODEL_ID):
        self.region = region
        self.model_id = model_id
        self.cache = {}
        self.bedrock_runtime = boto3.client('bedrock-runtime', region_name=region, config=BEDROCK_CONFIG)
        logger.info(f"Bedrock client initialized with model {model_id} in {region}")

    @bedrock_retry(max_retries=3)
    def _invoke_llm(self, prompt, max_tokens=4000):
        body = json.dumps({
            "prompt": prompt,
            "max_gen_len": max_tokens,
            "temperature": 0.0,
            "top_p": 0.9
        })
        response = self.bedrock_runtime.invoke_model(
            modelId=self.model_id,
            contentType='application/json',
            accept='application/json',
            body=body
        )
        response_body = json.loads(response['body'].read())
        return response_body.get('generation', '').strip()

    def _extract_json(self, text):
        if not text or not text.strip():
            raise ValueError("Empty response from LLM")
        text = text.strip()
        text = re.sub(r'```json\s*', '', text)
        text = re.sub(r'```\s*$', '', text)
        first_brace = text.find('{')
        last_brace = text.rfind('}')
        if first_brace != -1 and last_brace != -1 and last_brace > first_brace:
            json_candidate = text[first_brace:last_brace+1]
        else:
            json_candidate = text
        json_candidate = re.sub(r',\s*}', '}', json_candidate)
        json_candidate = re.sub(r',\s*]', ']', json_candidate)
        try:
            return json.loads(json_candidate)
        except json.JSONDecodeError:
            pattern = r'"([^"]+)"\s*:\s*"([^"]*)"'
            matches = re.findall(pattern, json_candidate)
            if matches:
                return {k: v for k, v in matches}
            raise ValueError(f"Could not extract JSON: {text[:200]}")

    def _translate_chunk(self, chunk_names):
        names_list = "\n".join(f"- {name}" for name in chunk_names)
        prompt = (
            f"<|begin_of_text|><|start_header_id|>user<|end_header_id|>\n\n"
            f"You are an SAP expert. Convert the following German column names to English business terms.\n"
            f"**MANDATORY**: Return a valid JSON object with a key for EVERY German name listed.\n"
            f"**DO NOT include any explanatory text, backticks, or markdown. Return ONLY the JSON object.**\n\n"
            f"Use UPPERCASE with underscores.\n\n"
            f"Examples: 'lifnr' -> 'VENDOR_ID', 'bukrs' -> 'COMPANY_CODE', 'belnr' -> 'DOCUMENT_NUMBER', "
            f"'gjahr' -> 'FISCAL_YEAR', 'matnr' -> 'MATERIAL_NUMBER', 'werks' -> 'PLANT', 'ebeln' -> 'PURCHASE_ORDER_NUMBER'\n\n"
            f"German column names:\n{names_list}\n\n"
            f"JSON output:\n"
            f"<|eot_id|><|start_header_id|>assistant<|end_header_id|>\n\n"
        )
        raw_response = self._invoke_llm(prompt)
        mapping = self._extract_json(raw_response)
        missing = [name for name in chunk_names if name not in mapping]
        if missing:
            # Retry with simpler prompt
            prompt2 = (
                f"<|begin_of_text|><|start_header_id|>user<|end_header_id|>\n\n"
                f"Return ONLY a JSON object. The JSON must have keys for all names below.\n"
                f"Example: {{\"lifnr\": \"VENDOR_ID\", \"bukrs\": \"COMPANY_CODE\"}}\n\n"
                f"Names: {', '.join(chunk_names)}\n\n"
                f"JSON:\n"
                f"<|eot_id|><|start_header_id|>assistant<|end_header_id|>\n\n"
            )
            raw_response2 = self._invoke_llm(prompt2)
            mapping2 = self._extract_json(raw_response2)
            missing2 = [name for name in chunk_names if name not in mapping2]
            if missing2:
                raise RuntimeError(f"Missing {len(missing2)} names: {missing2[:10]}...")
            mapping = mapping2
        return mapping

    def translate_batch(self, all_german_names):
        to_translate = [name for name in all_german_names if name not in self.cache]
        if not to_translate:
            return {name: self.cache[name] for name in all_german_names}
        chunks = [to_translate[i:i+TRANSLATION_BATCH_SIZE] for i in range(0, len(to_translate), TRANSLATION_BATCH_SIZE)]
        logger.info(f"Translating {len(to_translate)} names in {len(chunks)} chunks")
        for idx, chunk in enumerate(chunks):
            chunk_map = self._translate_chunk(chunk)
            self.cache.update(chunk_map)
            logger.info(f"Chunk {idx+1} done, cache size {len(self.cache)}")
        missing_final = [name for name in all_german_names if name not in self.cache]
        if missing_final:
            raise RuntimeError(f"Still missing {len(missing_final)} names after all chunks")
        return {name: self.cache[name] for name in all_german_names}

    def rename_columns(self, df, translation_map):
        # rename using the translation map, then deduplicate
        original_columns = df.columns
        name_counts = {}
        rename_map = {}
        for old in original_columns:
            new_base = translation_map.get(old, old.upper())
            if new_base not in name_counts:
                rename_map[old] = new_base
                name_counts[new_base] = 1
            else:
                cnt = name_counts[new_base] + 1
                new_name = f"{new_base}_{cnt}"
                rename_map[old] = new_name
                name_counts[new_base] = cnt
        for old, new in rename_map.items():
            df = df.withColumnRenamed(old, new)
        # final deduplication (safety)
        df = deduplicate_columns(df)
        logger.info(f"Renamed and deduplicated {len(rename_map)} columns")
        return df

# --------------------------------------------------------------
# Helper: Deduplicate column names in a DataFrame
# --------------------------------------------------------------
def deduplicate_columns(df):
    """Rename duplicate columns (case-insensitive) by appending _2, _3 etc."""
    cols = df.columns
    new_cols = []
    counts = {}
    for c in cols:
        upper_c = c.upper()
        if upper_c not in counts:
            counts[upper_c] = 1
            new_cols.append(c)
        else:
            counts[upper_c] += 1
            new_cols.append(f"{c}_{counts[upper_c]}")
    if new_cols != list(cols):
        logger.warning(f"Deduplicated columns: {list(zip(cols, new_cols))}")
        df = df.toDF(*new_cols)
    return df

