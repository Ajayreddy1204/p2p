# --------------------------------------------------------------
def main():
    logger.info("Starting Silver Layer (Raw Vault) Job with English column names")
    logger.info("=" * 60)

    # Create HUBs first
    hub_paths = create_hubs()

    # Create SATELLITEs
    create_satellites(hub_paths)

    # Create LINKs
    create_links(hub_paths)

    logger.info("=" * 60)
    logger.info("Silver Layer (Raw Vault) Job Completed Successfully - all 37 tables created")

if __name__ == "__main__":
    main()
    job.commit()
